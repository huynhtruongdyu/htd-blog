---
import "../styles/main.scss";
import Metadata from "../components/Metadata.astro";

interface Props {
    title?: string;
    description?: string;
    image?: string;
}

const { title, description, image } = Astro.props;
const lang = Astro.currentLocale || "en";
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <Metadata title={title} description={description} image={image} />
</head>
<body>
    <slot/>
</body>
</html>