---
import "../styles/main.scss";
import Metadata from "../components/Metadata.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ClientRouter from "astro/components/ClientRouter.astro";

interface Props {
    title?: string;
    description?: string;
    image?: string;
    type?: 'website' | 'article';
    pubDate?: Date;
    tags?: string[];
    noindex?: boolean;
    alternateUrl?: string;
}

const {
    title,
    description,
    image,
    type = 'website',
    pubDate,
    tags = [],
    noindex = false,
    alternateUrl,
} = Astro.props;
const lang = Astro.currentLocale || "en";
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <ClientRouter fallback="animate" />
    <Metadata
        title={title}
        description={description}
        image={image}
        type={type}
        locale={lang}
        pubDate={pubDate}
        tags={tags}
        noindex={noindex}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500&family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-TV4LGB3N5D"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-TV4LGB3N5D');
    </script>
    <script>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "umd75e5v3e");
    </script>
</head>
<body>
    <Header locale={lang} pathname={Astro.url.pathname} alternateUrl={alternateUrl} />
    <main transition:animate="slide">
        <slot/>
    </main>
    <Footer locale={lang} />
</body>
</html>
