---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Liên hệ" description="Liên hệ với Duy Huynh. Có một dự án trong đầu hoặc chỉ muốn nói lời chào?">
  <div class="container container--narrow">
    <div class="section-label">
      <span class="section-label__line"></span>
      <span class="section-label__text">Liên hệ</span>
      <span class="section-label__line"></span>
    </div>

    <h1 class="page-title">Liên Hệ</h1>

    <p class="contact__intro">
      Có một dự án trong đầu hoặc chỉ muốn nói lời chào? Hãy gửi email cho tôi và tôi sẽ trả lời bạn.
    </p>

    <div class="contact__alt">
      <a href="mailto:contact@duyhuynh.net" class="contact__email">contact@duyhuynh.net</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
    color: var(--color-foreground);
  }

  .contact__intro {
    color: var(--color-muted-foreground);
    line-height: 1.75;
    margin-bottom: 2.5rem;
  }

  .contact__alt {
    text-align: center;
  }

  .contact__email {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .contact__email:hover {
    color: var(--color-accent-secondary);
  }
</style>
