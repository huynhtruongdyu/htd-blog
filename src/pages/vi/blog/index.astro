---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import BlogCard from "../../../components/BlogCard.astro";

const allPosts = await getCollection("blog", ({ id }) => id.startsWith("vi/"));
const posts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Blog">
  <div class="container container--narrow">
    <div class="section-label">
      <span class="section-label__line"></span>
      <span class="section-label__text">Blog</span>
      <span class="section-label__line"></span>
    </div>

    <h1 class="page-title">Bài Viết</h1>

    {posts.length > 0 ? (
      <div class="posts-list">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id.replace("vi/", "").replace(".md", "")}
            tags={post.data.tags}
            locale="vi"
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">Chưa có bài viết nào.</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
    color: var(--color-foreground);
  }

  .empty-state {
    text-align: center;
    color: var(--color-muted-foreground);
    padding: 4rem 0;
  }
</style>
