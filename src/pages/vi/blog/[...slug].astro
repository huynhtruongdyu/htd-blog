---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { SITE_URL } from "../../../consts";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ id }) => id.startsWith("vi/"));
  return posts.map((post) => ({
    params: { slug: post.id.replace("vi/", "").replace(/\.md$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString("vi-VN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

let alternateUrl;
if (post.data.translationKey) {
  const allPosts = await getCollection("blog");
  const translation = allPosts.find(
    (p) => p.data.translationKey === post.data.translationKey && p.id.startsWith("en/")
  );
  if (translation) {
    const slug = translation.id.replace("en/", "").replace(/\.md$/, "");
    alternateUrl = `/blog/${slug}/`;
  }
}

const pageUrl = new URL(Astro.url.pathname, SITE_URL).href;
const facebookShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`;
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.heroImage} type="article" pubDate={post.data.pubDate} tags={post.data.tags} alternateUrl={alternateUrl}>
  <article class="container container--narrow">
    <div class="post-meta">
      <a href="/vi/blog" class="post-back small-caps">&larr; Quay lại</a>
      <time class="post-date small-caps" datetime={post.data.pubDate.toISOString()}>
        {formattedDate}
      </time>
    </div>

    <h1 class="post-title">{post.data.title}</h1>

    {post.data.tags.length > 0 && (
      <div class="post-tags">
        {post.data.tags.map((tag) => (
          <span class="post-tag small-caps">{tag}</span>
        ))}
      </div>
    )}

    <div class="prose post-content">
      <Content />
    </div>

    <div class="post-share">
      <span class="share-label small-caps">Chia sẻ</span>
      <a href={facebookShareUrl} target="_blank" rel="noopener noreferrer" class="share-link" aria-label="Chia sẻ lên Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        Facebook
      </a>
    </div>
  </article>
</BaseLayout>

<style>
  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .post-back {
    color: var(--color-accent);
    text-decoration: none;
    font-size: 0.75rem;
    transition: opacity var(--transition-fast);
  }

  .post-back:hover {
    opacity: 0.8;
  }

  .post-date {
    color: var(--color-muted-foreground);
    font-size: 0.7rem;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--color-foreground);
  }

  .post-tags {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .post-tag {
    font-size: 0.65rem;
    color: var(--color-muted-foreground);
    background: var(--color-muted);
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-sm);
  }

  .post-content {
    padding-bottom: 2rem;
  }

  .post-share {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-muted);
    margin-bottom: 4rem;
  }

  .share-label {
    font-size: 0.65rem;
    color: var(--color-muted-foreground);
  }

  .share-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .share-link:hover {
    opacity: 0.8;
  }
</style>
