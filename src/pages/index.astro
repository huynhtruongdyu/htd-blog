---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import BlogCard from "../components/BlogCard.astro";
import ProjectCard from "../components/ProjectCard.astro";

const posts = await getCollection("blog", ({ id }) => id.startsWith("en/"));
const projects = await getCollection("projects", ({ id }) => id.startsWith("en/"));

const latestPosts = posts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 2);

const featuredProjects = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Home">
  <section class="hero">
    <div class="container container--narrow">
      <span class="hero__label small-caps">Welcome</span>
      <h1 class="hero__title">Duy Huynh</h1>
      <p class="hero__subtitle">
        Software engineer &amp; designer crafting thoughtful digital experiences with clean typography and refined aesthetics.
      </p>
    </div>
  </section>

  {featuredProjects.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-label">
          <span class="section-label__line"></span>
          <span class="section-label__text">Selected Work</span>
          <span class="section-label__line"></span>
        </div>
        <div class="projects-grid">
          {featuredProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              url={project.data.url}
              github={project.data.github}
              featured={project.data.featured}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {latestPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-label">
          <span class="section-label__line"></span>
          <span class="section-label__text">Latest Writing</span>
          <span class="section-label__line"></span>
        </div>
        <div>
          {latestPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id.replace("en/", "").replace(".md", "")}
              tags={post.data.tags}
              locale="en"
            />
          ))}
        </div>
        <div style="margin-top: 2rem; text-align: center;">
          <a href="/blog" class="button button--ghost">View all posts</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding: 6rem 0 4rem;
    text-align: center;
  }

  .hero__label {
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    display: inline-block;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--color-foreground);
  }

  .hero__subtitle {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--color-muted-foreground);
    max-width: 36rem;
    margin: 0 auto;
  }

  .section {
    padding: 4rem 0;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 4rem 0 2rem;
    }

    .section {
      padding: 2rem 0;
    }
  }
</style>
