---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";
import BlogCard from "../components/BlogCard.astro";
import ProjectCard from "../components/ProjectCard.astro";

const posts = await getCollection("blog", ({ id }) => id.startsWith("en/"));
const projects = await getCollection("projects", ({ id }) => id.startsWith("en/"));

const latestPosts = posts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 2);

const featuredProjects = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Home" description={SITE_DESCRIPTION}>
  <section class="hero">
    <div class="container container--narrow">
      <div class="hero__codeblock"><code>Console.WriteLine(<span class="hero__string">"Hello World"</span>);</code></div>
      <h1 class="hero__title">Duy Huynh</h1>
      <p class="hero__slogan">Less Code, No Vibe, No Hype</p>
    </div>
  </section>

  {featuredProjects.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-label">
          <span class="section-label__line"></span>
          <span class="section-label__text">Selected Work</span>
          <span class="section-label__line"></span>
        </div>
        <div class="projects-grid">
          {featuredProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              slug={project.id.replace("en/", "").replace(".md", "")}
              locale="en"
              github={project.data.github}
              featured={project.data.featured}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {latestPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-label">
          <span class="section-label__line"></span>
          <span class="section-label__text">Latest Writing</span>
          <span class="section-label__line"></span>
        </div>
        <div>
          {latestPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id.replace("en/", "").replace(".md", "")}
              tags={post.data.tags}
              locale="en"
            />
          ))}
        </div>
        <div style="margin-top: 2rem; text-align: center;">
          <a href="/blog" class="button button--ghost">View all posts</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding: 5rem 0 3rem;
    text-align: center;
  }

  .hero__codeblock {
    display: inline-block;
    background: var(--color-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.4rem 0.85rem;
    margin-bottom: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-accent);
  }

  .hero__codeblock code {
    font-family: inherit;
    color: inherit;
  }

  .hero__string {
    color: var(--color-foreground);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 0.75rem;
    color: var(--color-foreground);
  }

  .hero__slogan {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .section {
    padding: 3rem 0;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 0 2rem;
    }

    .section {
      padding: 2rem 0;
    }
  }
</style>
