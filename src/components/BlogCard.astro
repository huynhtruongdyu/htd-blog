---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  locale?: string;
}

const { title, description, pubDate, slug, tags = [], locale = "en" } = Astro.props;
const prefix = locale === "en" ? "" : "/vi";
const formattedDate = pubDate.toLocaleDateString(locale === "en" ? "en-US" : "vi-VN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="blog-card">
  <a href={`${prefix}/blog/${slug}`} class="blog-card__link">
    <time class="blog-card__date small-caps" datetime={pubDate.toISOString()}>
      {formattedDate}
    </time>
    <h3 class="blog-card__title">{title}</h3>
    <p class="blog-card__description">{description}</p>
    {tags.length > 0 && (
      <div class="blog-card__tags">
        {tags.map((tag) => (
          <span class="blog-card__tag small-caps">{tag}</span>
        ))}
      </div>
    )}
  </a>
</article>

<style>
  .blog-card {
    border-bottom: 1px solid var(--color-border);
    padding: 2rem 0;
    transition: opacity var(--transition-fast);
  }

  .blog-card:first-of-type {
    padding-top: 0;
  }

  .blog-card__link {
    text-decoration: none;
    display: block;
  }

  .blog-card__link:hover {
    opacity: 0.85;
  }

  .blog-card__date {
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    display: inline-block;
  }

  .blog-card__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .blog-card__description {
    color: var(--color-muted-foreground);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .blog-card__tags {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .blog-card__tag {
    font-size: 0.65rem;
    color: var(--color-muted-foreground);
    background: var(--color-muted);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
  }
</style>
