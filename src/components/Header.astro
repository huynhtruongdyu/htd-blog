---
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  locale?: string;
  pathname?: string;
  alternateUrl?: string;
}

const { locale = "en", pathname = "/", alternateUrl } = Astro.props;

const nav = locale === "en"
  ? [
      { href: "/", label: "Home" },
      { href: "/about", label: "About" },
      { href: "/projects", label: "Projects" },
      { href: "/blog", label: "Blog" },
      { href: "/contact", label: "Contact" },
    ]
  : [
      { href: "/vi/", label: "Trang chủ" },
      { href: "/vi/about", label: "Giới thiệu" },
      { href: "/vi/projects", label: "Dự án" },
      { href: "/vi/blog", label: "Blog" },
      { href: "/vi/contact", label: "Liên hệ" },
    ];

const otherLocale = locale === "en" ? "vi" : "en";
const langPath = alternateUrl ?? (locale === "en" ? `/vi${pathname === "/" ? "" : pathname}` : pathname.replace(/^\/vi/, "") || "/");
const langLabel = otherLocale.toUpperCase();
---

<header class="header">
  <div class="header__inner container">
    <a href={locale === "en" ? "/" : "/vi/"} class="header__logo" aria-label="Home">
      <span class="small-caps">Duy Huynh</span>
    </a>

    <button class="header__hamburger" id="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="header__hamburger-bar"></span>
      <span class="header__hamburger-bar"></span>
      <span class="header__hamburger-bar"></span>
    </button>

    <nav class="header__nav" id="main-nav" aria-label="Main navigation">
      <div class="header__nav-links">
        {nav.map((item) => {
          const isActive = pathname === item.href || (item.href !== "/" && item.href !== "/vi/" && pathname.startsWith(item.href));
          return (
            <a
              href={item.href}
              class={`header__nav-link ${isActive ? "header__nav-link--active" : ""}`}
              aria-current={isActive ? "page" : undefined}
              aria-disabled={isActive ? "true" : undefined}
              tabindex={isActive ? -1 : undefined}
            >
              {item.label}
            </a>
          );
        })}
      </div>
      <div class="header__nav-actions">
        <a href={langPath} class="header__lang" aria-label={`Switch to ${otherLocale}`}>
          {langLabel}
        </a>
        <ThemeToggle />
      </div>
    </nav>
  </div>
</header>

<style>
  .header {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header__logo {
    text-decoration: none;
    color: var(--color-foreground);
    z-index: 110;
  }

  .header__logo .small-caps {
    font-size: 0.875rem;
    letter-spacing: 0.12em;
  }

  .header__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    border: none;
    background: none;
    cursor: pointer;
    z-index: 110;
    touch-action: manipulation;
  }

  .header__hamburger-bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--color-foreground);
    border-radius: 1px;
    transition: all var(--transition-normal);
    transform-origin: center;
  }

  .header__hamburger[aria-expanded="true"] .header__hamburger-bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }

  .header__hamburger[aria-expanded="true"] .header__hamburger-bar:nth-child(2) {
    opacity: 0;
  }

  .header__hamburger[aria-expanded="true"] .header__hamburger-bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .header__nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .header__nav-actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 0.5rem;
  }

  .header__nav-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-muted-foreground);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast);
    touch-action: manipulation;
    white-space: nowrap;
  }

  .header__nav-link:hover {
    color: var(--color-foreground);
  }

  .header__nav-link--active {
    color: var(--color-accent);
  }

  .header__lang {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-muted-foreground);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    touch-action: manipulation;
  }

  .header__lang:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .header {
      padding: 1rem 0;
      margin-bottom: 1.5rem;
    }

    .header__hamburger {
      display: flex;
    }

    .header__nav {
      position: fixed;
      inset: 0;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 2rem;
      background: var(--color-bg);
      z-index: 100;
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--transition-normal);
    }

    .header__nav.is-open {
      opacity: 1;
      pointer-events: auto;
    }

    .header__nav-links {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    .header__nav-link {
      font-size: 1rem;
      padding: 0.75rem 1.5rem;
    }

    .header__nav-actions {
      margin-left: 0;
      gap: 0.75rem;
    }

    .header__lang {
      padding: 0.6rem 1rem;
      font-size: 0.75rem;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const toggle = document.getElementById("menu-toggle");
    const nav = document.getElementById("main-nav");
    if (!toggle || !nav) return;

    let isOpen = false;

    const toggleMenu = (open) => {
      isOpen = open !== undefined ? open : !isOpen;
      toggle.setAttribute("aria-expanded", String(isOpen));
      nav.classList.toggle("is-open", isOpen);
      document.body.style.overflow = isOpen ? "hidden" : "";
    };

    toggle.onclick = () => toggleMenu();

    const isActive = (link) => link.getAttribute("aria-disabled") === "true";

    nav.querySelectorAll("a").forEach((link) => {
      if (isActive(link)) {
        link.onclick = (e) => e.preventDefault();
      } else {
        link.onclick = () => toggleMenu(false);
      }
    });
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      const toggle = document.getElementById("menu-toggle");
      if (toggle && toggle.getAttribute("aria-expanded") === "true") {
        toggle.click();
        toggle.focus();
      }
    }
  });
</script>
